# FinAnaliz Pro — Netlify _headers
# public/ dizinine yerleştirin

# ─── Tüm sayfalar için güvenlik başlıkları ──────────────────
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://identity.netlify.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.anthropic.com https://*.supabase.co https://identity.netlify.com; frame-ancestors 'none'; object-src 'none'
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# ─── Netlify Functions — API endpoint'leri ──────────────────
/.netlify/functions/*
  Cache-Control: no-store, no-cache, must-revalidate
  X-Robots-Tag: noindex, nofollow

# ─── API proxy route'ları ────────────────────────────────────
/api/*
  Cache-Control: no-store, no-cache, must-revalidate
  X-Robots-Tag: noindex, nofollow
  X-Content-Type-Options: nosniff

# ─── index.html — asla önbelleklenmemeli ─────────────────────
/index.html
  Cache-Control: no-store, no-cache, must-revalidate
  X-Robots-Tag: noindex

# ─── Statik varlıklar ────────────────────────────────────────
/assets/*
  Cache-Control: public, max-age=31536000, immutable
